---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CredibilityStrip from "../components/CredibilityStrip.astro";

const credibilidad = [
  { icon: "🔧", number: "20+ años", label: "de trayectoria técnica" },
  { icon: "🎯", number: "Especialista", label: "exclusivo en calderas Peisa" },
  { icon: "🤝", number: "Directo", label: "con el técnico, sin call center" },
  { icon: "📍", number: "Villa Urquiza", label: "CABA" },
];
---

<BaseLayout
  title="El técnico — Criterio Térmico"
  description="20 años de experiencia en calderas Peisa. Técnico especialista en Villa Urquiza, CABA. Repuestos originales y asesoramiento técnico directo."
>
  <section class="section" style="padding-bottom: var(--space-10);">
    <div class="container container--narrow">
      <Breadcrumbs items={[{ label: "El técnico" }]} />

      <div class="about-hero">
        <h1>Criterio Térmico</h1>
        <p class="hero__subtitle" style="margin-top: var(--space-4); color: var(--color-text-secondary);">
          20 años de experiencia técnica real, del otro lado de cada repuesto que vendemos.
        </p>
      </div>
    </div>
  </section>

  <section class="credibility-band">
    <div class="container container--narrow">
      <CredibilityStrip items={credibilidad} />
    </div>
  </section>

  <section class="section" style="background: var(--color-trust-bar); padding-block: var(--space-12);">
    <div class="container container--narrow">
      <div class="premium-row">
        <div class="premium-row__media">
          <img src="/images/nosotros/taller-detalle.jpg" alt="Manos instalando un repuesto en una caldera Peisa" loading="lazy" width="1856" height="2304"/>
        </div>
        <div class="premium-row__text">
          <span class="premium-row__badge">Quién está del otro lado del WhatsApp</span>
          <h2 style="margin-bottom: var(--space-4);">Mi oficio, en cada diagnóstico</h2>
          <p class="premium-row__desc">
            Soy Edgardo. Hace más de veinte años que reparo e instalo calderas Peisa:
            aprendí en la casa de la gente, con la calefacción cortada y el frío
            apurando.
          </p>
          <p class="premium-row__desc">
            Por eso Criterio Térmico no es una tienda anónima — cuando escribís, te
            contesto yo, con el mismo criterio que aplico frente a la caldera.
          </p>
          <p style="font-size: 16px; line-height: 1.6; color: var(--color-text-tertiary); font-style: italic; margin-top: 8px;">
            «No te vendo el repuesto más caro. Te vendo el que tu caldera necesita.»
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <div class="article-content">
        <h2>Conocimiento técnico real</h2>
        <p>
          Criterio Térmico nace de la experiencia directa con calderas Peisa.
          No somos un catálogo online genérico — somos un técnico especialista que
          conoce cada modelo, cada falla y cada solución.
        </p>
        <p>
          Cuando consultás por un repuesto, no te mandamos una pieza y listo.
          Te preguntamos qué síntoma tiene tu caldera, verificamos que el repuesto
          sea el correcto para tu modelo, y te damos las indicaciones para instalarlo.
        </p>

        <h2>¿Por qué "Criterio" Térmico?</h2>
        <p>
          Porque vender un repuesto sin saber si es el correcto no tiene criterio.
          Cada pieza que ofrecemos viene con el respaldo de saber exactamente
          por qué se cambió, qué síntoma resuelve y cómo se instala.
        </p>

        <h2>Ubicación y retiro</h2>
        <p>
          Estamos en <strong>Villa Urquiza, CABA</strong>. Los repuestos se retiran
          en persona, coordinando previamente por WhatsApp. No hacemos envíos por
          el momento — queremos asegurarnos de que cada pieza sea la correcta
          antes de entregarla.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
