---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PriceDisplay from "../../components/PriceDisplay.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SchemaMarkup from "../../components/SchemaMarkup.astro";
import { siteConfig } from "../../config/site";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const repuestos = await getCollection("repuestos");
  return repuestos.map((item) => {
    return {
      params: { slug: item.data.slug },
      props: { repuesto: item.data },
    };
  });
}

const { repuesto } = Astro.props;

const diagnosticos = await getCollection("diagnostico");
const guiasRelacionadas = diagnosticos.filter((d) =>
  d.data.repuestos_relacionados?.includes(repuesto.slug)
);

const codigoDisplay = repuesto.codigo ? ` (${repuesto.codigo})` : "";

// Galería: usa imagenes[] si están cargadas; si no, cae a la imagen única.
const galeria = (repuesto.imagenes && repuesto.imagenes.length > 0)
  ? repuesto.imagenes
  : [repuesto.imagen];

const compraMensaje = `Hola, quiero comprar el ${repuesto.nombre}${codigoDisplay}. ¿Me confirmás disponibilidad, precio del día y cómo coordinamos la entrega?`;
const seoTitle = repuesto.codigo
  ? `${repuesto.nombre}${codigoDisplay} — Repuesto original Peisa | Criterio Térmico`
  : `${repuesto.nombre} — Repuesto original Peisa | Criterio Térmico`;
const seoDescription = `${repuesto.nombre} para ${repuesto.modelos_compatibles.slice(0, 3).join(", ")}. Repuesto original Peisa disponible para retiro en Villa Urquiza, CABA. Asesoramiento técnico incluido.`;
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SchemaMarkup type="product" data={repuesto} />
  <SchemaMarkup
    type="breadcrumb"
    data={{
      items: [
        { name: "Inicio", url: `${siteConfig.dominio}/` },
        { name: "Repuestos", url: `${siteConfig.dominio}/repuestos` },
        { name: repuesto.nombre, url: `${siteConfig.dominio}/repuestos/${repuesto.slug}` },
      ],
    }}
  />

  <section class="section--tight">
    <div class="container container--mid">
      <Breadcrumbs
        items={[
          { label: "Repuestos", href: "/repuestos" },
          { label: repuesto.nombre },
        ]}
      />

      <div class="product-detail" style="margin-top: 26px;">
        <div class="gallery" data-gallery>
          <div class="product-detail__media gallery__stage">
            <img src={galeria[0]} alt={repuesto.nombre} width="600" height="600" data-gallery-main />
            <span class="product-detail__badge">
              <span class="product-card__badge-dot"></span>
              {repuesto.disponible ? "Disponible" : "Sin stock"}
            </span>
          </div>
          {galeria.length > 1 && (
            <div class="gallery__thumbs">
              {galeria.map((img: string, i: number) => (
                <button
                  type="button"
                  class:list={["gallery__thumb", i === 0 && "is-active"]}
                  data-gallery-thumb
                  data-src={img}
                  aria-label={`Ver foto ${i + 1} de ${galeria.length}`}
                >
                  <img src={img} alt="" width="64" height="64" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="product-detail__info">
          {repuesto.codigo && (
            <span class="product-detail__code">COD {repuesto.codigo} · {repuesto.marca || "Peisa"} original</span>
          )}

          <h1>{repuesto.nombre}</h1>

          <p class="product-detail__desc">{repuesto.descripcion}</p>

          <div class="product-detail__price-box">
            <span class="product-detail__price-label">Precio</span>
            <PriceDisplay precioUsd={repuesto.precio_usd} precioArs={repuesto.precio_ars} />
            <p class="price-note" style="margin-top: 4px;">
              Te confirmamos disponibilidad y precio del día al instante.
            </p>
            <div class="product-detail__buy">
              <WhatsAppButton
                mensaje={compraMensaje}
                texto="Comprar por WhatsApp"
                class="whatsapp-btn--full"
              />
              <WhatsAppButton
                mensaje={repuesto.whatsapp_mensaje}
                texto="Consultar antes de comprar"
                class="whatsapp-btn--full whatsapp-btn--ghost"
              />
            </div>
          </div>

          <div class="product-detail__models">
            <span class="product-detail__models-label">Modelos compatibles</span>
            {repuesto.modelos_compatibles.map((modelo: string) => (
              <span class="product-detail__model-tag">{modelo}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="detail-columns">
        <div class="detail-box">
          <div class="detail-box__header">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#b8790a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
              <line x1="12" y1="9" x2="12" y2="13" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
            <h2>Síntomas típicos</h2>
          </div>
          <ul class="symptoms__list">
            {repuesto.sintomas.map((sintoma: string) => (
              <li class="symptoms__item">{sintoma}</li>
            ))}
          </ul>
        </div>

        <div class="detail-box">
          <h2 style="font-family: var(--font-heading); font-weight: 700; font-size: 19px; margin-bottom: 16px;">
            Guías relacionadas
          </h2>
          <div style="display: flex; flex-direction: column; gap: 11px;">
            {guiasRelacionadas.map((guia) => (
              <a href={`/diagnostico/${guia.id}`} class="install-link">
                <span style="font-size: 20px;">📘</span>
                <div>
                  <div class="install-link__text">{guia.data.title}</div>
                  <div class="install-link__sub">{guia.data.categoria}</div>
                </div>
              </a>
            ))}
            {repuesto.guia_instalacion_slug && (
              <a href={`/instalacion/${repuesto.guia_instalacion_slug}`} class="install-link">
                <span style="font-size: 20px;">🔧</span>
                <div>
                  <div class="install-link__text">Ver guía de instalación</div>
                  <div class="install-link__sub">Paso a paso para reemplazar esta pieza</div>
                </div>
              </a>
            )}
            {guiasRelacionadas.length === 0 && !repuesto.guia_instalacion_slug && (
              <p style="color: var(--color-text-muted); font-size: 14.5px;">
                Todavía no hay guías publicadas para esta pieza — consultanos por WhatsApp.
              </p>
            )}
          </div>
        </div>
      </div>

      <div class="dark-cta" style="margin-top: clamp(40px, 5vw, 64px);">
        <div class="dark-cta__text">
          <h2>¿No estás seguro si es tu repuesto?</h2>
          <p>Pasame el modelo de tu caldera y el número de serie. Te confirmo la compatibilidad antes de que compres.</p>
        </div>
        <WhatsAppButton mensaje={repuesto.whatsapp_mensaje} texto="Consultar disponibilidad" />
      </div>
    </div>
  </section>

  <script>
    // Galería tipo MercadoLibre: la miniatura activa cambia la imagen grande.
    // En desktop cambia también con el hover; en touch, con el tap.
    document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
      const main = gallery.querySelector<HTMLImageElement>("[data-gallery-main]");
      const thumbs = gallery.querySelectorAll<HTMLButtonElement>("[data-gallery-thumb]");
      if (!main || thumbs.length < 2) return;

      const activate = (thumb: HTMLButtonElement) => {
        const src = thumb.getAttribute("data-src");
        if (!src) return;
        main.setAttribute("src", src);
        thumbs.forEach((t) => t.classList.remove("is-active"));
        thumb.classList.add("is-active");
      };

      thumbs.forEach((thumb) => {
        thumb.addEventListener("click", () => activate(thumb));
        thumb.addEventListener("mouseenter", () => activate(thumb));
      });
    });
  </script>
</BaseLayout>
