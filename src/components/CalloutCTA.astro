---
interface Props {
  title: string;
  href: string;
  cta: string;
}

const { title, href, cta } = Astro.props;
---

<div class="callout-box">
  <div class="callout-box__title">{title}</div>
  <div class="callout-box__body"><slot /></div>
  <a href={href} class="btn btn--primary btn--sm">{cta}</a>
</div>
