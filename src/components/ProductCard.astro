---
import WhatsAppButton from "./WhatsAppButton.astro";

interface Props {
  nombre: string;
  codigo: string;
  slug: string;
  imagen: string;
  disponible: boolean;
  modelos_compatibles: string[];
  whatsapp_mensaje: string;
}

const { nombre, codigo, slug, imagen, disponible, modelos_compatibles, whatsapp_mensaje } = Astro.props;
---

<div class="product-card">
  <div class="product-card__media">
    <img src={imagen} alt={nombre} loading="lazy" />
    <span class={`product-card__badge ${disponible ? "" : "product-card__badge--unavailable"}`}>
      <span class="product-card__badge-dot"></span>
      {disponible ? "Disponible" : "Sin stock"}
    </span>
  </div>
  <div class="product-card__body">
    {codigo && <span class="product-card__code">COD {codigo}</span>}
    <h3 class="product-card__title">{nombre}</h3>
    <p class="product-card__models">{modelos_compatibles.slice(0, 3).join(" · ")}</p>
    <div class="product-card__actions">
      <WhatsAppButton mensaje={whatsapp_mensaje} texto="Consultar precio" class="whatsapp-btn--sm" />
      <a href={`/repuestos/${slug}`} class="product-card__link">Ver ficha completa →</a>
    </div>
  </div>
</div>
