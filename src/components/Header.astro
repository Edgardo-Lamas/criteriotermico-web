---
import { siteConfig } from "../config/site";
import WhatsAppButton from "./WhatsAppButton.astro";

interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;

const navLinks = [
  { href: "/diagnostico", label: "Diagnóstico" },
  { href: "/repuestos", label: "Repuestos" },
  { href: "/nosotros", label: "El técnico" },
  { href: "/#trabajos", label: "Trabajos" },
  { href: "/notas", label: "Notas" },
];
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo">
      <span class="header__logo-icon">
        <img src="/logo-mark.png" alt="Criterio Térmico" />
      </span>
      <span class="header__logo-text">Criterio<span class="dot">·</span>Térmico</span>
    </a>

    <nav class="header__nav" id="nav-menu">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={!link.href.includes("#") && currentPath.startsWith(link.href) ? "active" : ""}
        >
          {link.label}
        </a>
      ))}
      <a href="/para-tecnicos" class="nav--new">
        Para técnicos <span class="badge-new">NUEVO</span>
      </a>
    </nav>

    <div class="header__cta">
      <WhatsAppButton
        mensaje={siteConfig.whatsappMensajeGenerico}
        texto="Consultar"
        class="whatsapp-btn--header"
      />
    </div>

    <button
      class="header__menu-btn"
      id="menu-toggle"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const nav = document.getElementById("nav-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(isOpen));
  });

  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      nav.classList.remove("open");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
