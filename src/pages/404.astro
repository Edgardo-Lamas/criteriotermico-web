---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Página no encontrada — Criterio Térmico"
  description="La página que buscás no existe. Visitá nuestro catálogo de repuestos Peisa o contactanos por WhatsApp."
>
  <div class="error-page">
    <div class="error-page__code">404</div>
    <h1>Página no encontrada</h1>
    <p>La página que buscás no existe o fue movida. Probá con alguna de estas opciones:</p>
    <div class="hero__actions" style="justify-content: center;">
      <a href="/repuestos" class="btn btn--primary">Ver catálogo de repuestos</a>
      <a href="/" class="btn btn--outline">Volver al inicio</a>
    </div>
  </div>
</BaseLayout>
