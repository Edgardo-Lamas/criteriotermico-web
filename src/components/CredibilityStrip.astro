---
interface Item {
  icon: string;
  number: string;
  label: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="credibility-strip">
  {items.map((item) => (
    <div class="credibility-strip__item">
      <span class="credibility-strip__icon" aria-hidden="true">{item.icon}</span>
      <span>
        <span class="credibility-strip__number">{item.number}</span>
        <span class="credibility-strip__label">{item.label}</span>
      </span>
    </div>
  ))}
</div>
