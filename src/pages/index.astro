---
import BaseLayout from "../layouts/BaseLayout.astro";
import SchemaMarkup from "../components/SchemaMarkup.astro";
import CredibilityStrip from "../components/CredibilityStrip.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { siteConfig } from "../config/site";
import { getCollection } from "astro:content";

const repuestos = await getCollection("repuestos");
const repuestosDestacados = repuestos.slice(0, 4);
const diagnosticos = (await getCollection("diagnostico")).slice(0, 3);

const credibilidad = [
  { icon: "🔧", number: "20+ años", label: "de trayectoria técnica" },
  { icon: "🎓", number: "Matriculado", label: "técnico habilitado" },
  { icon: "⚙️", number: "Exclusivo", label: "especialista en calderas Peisa" },
  { icon: "📍", number: "Villa Urquiza", label: "CABA" },
];
---

<BaseLayout
  title="Criterio Térmico — 20 años de experiencia técnica en calderas Peisa"
  description="Técnico con 20 años de experiencia en calderas Peisa en Villa Urquiza, CABA. Diagnóstico, asesoramiento técnico y repuestos originales."
>
  <SchemaMarkup type="local-business" data={{}} />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__grid">
        <div class="hero__content">
          <span class="hero__badge">👷 20 años reparando calderas Peisa — Villa Urquiza, CABA</span>
          <h1>
            20 años de experiencia técnica en calderas Peisa,
            <span class="hero__accent">en cada repuesto que vendemos</span>
          </h1>
          <p class="hero__subtitle">
            Ventiladores, flujostatos, termostatos y válvulas para calderas Peisa.
            Identificamos tu problema, te damos el repuesto correcto y te guiamos para instalarlo.
          </p>
          <div class="hero__actions">
            <WhatsAppButton mensaje={siteConfig.whatsappMensajeGenerico} />
            <a href="/diagnostico" class="btn btn--secondary btn--lg">
              Ver diagnóstico técnico
            </a>
          </div>
        </div>
        <div class="hero__media">
          <img
            src="/images/home/hero-tecnico.jpg"
            alt="Técnico diagnosticando una caldera Peisa"
            width="1600"
            height="1200"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Credibility strip -->
  <section style="background: var(--color-bg-secondary); border-block: 1px solid var(--color-border);">
    <div class="container">
      <CredibilityStrip items={credibilidad} />
    </div>
  </section>

  <!-- Diagnóstico spotlight -->
  <section class="section">
    <div class="container">
      <div class="section-header" style="text-align: left;">
        <p class="section-header__label">Lo que nos diferencia</p>
        <h2>Diagnóstico técnico, no una tienda más</h2>
        <p class="section-header__desc" style="margin-inline: 0;">
          No vendemos repuestos al voleo. Estas guías vienen del mismo criterio con el
          que diagnosticamos cada caldera en 20 años de oficio.
        </p>
      </div>

      <div class="article-grid">
        {diagnosticos.map((articulo) => (
          <a href={`/diagnostico/${articulo.id}`} class="article-card">
            <span class="article-card__tag">{articulo.data.categoria}</span>
            <h3 class="article-card__title">{articulo.data.title}</h3>
            <p class="article-card__excerpt">{articulo.data.description}</p>
            <span class="article-card__link">Leer diagnóstico →</span>
          </a>
        ))}
      </div>

      <div style="text-align: center; margin-top: var(--space-8);">
        <a href="/diagnostico" class="btn btn--primary btn--lg">Ver todas las guías de diagnóstico →</a>
      </div>
    </div>
  </section>

  <!-- Sobre mí teaser -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <div class="premium-showcase">
        <div class="premium-row">
          <a href="/nosotros" class="premium-row__media">
            <img src="/images/home/sobre-mi-portrait.jpg" alt="Técnico especialista de Criterio Térmico" loading="lazy" />
          </a>
          <div class="premium-row__text">
            <span class="premium-row__badge">Quién está del otro lado del WhatsApp</span>
            <h3>20 años dedicados exclusivamente a calderas Peisa</h3>
            <p class="premium-row__desc">
              Cuando escribís, no te contesta un call center. Te contesto yo, con el
              criterio de dos décadas diagnosticando y reparando este mismo sistema de
              calefacción, uno a la vez.
            </p>
            <a href="/nosotros" class="btn btn--primary">Conocé mi historia →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Repuestos en fotos -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-header__label">Repuestos</p>
        <h2>Piezas que reparamos todos los días</h2>
        <p class="section-header__desc">
          Los repuestos que más se rompen en calderas Peisa. Tocá una foto para ver la ficha técnica completa.
        </p>
      </div>

      <div class="photo-grid">
        <a href="/repuestos/flujostato-bitron-onoff-90000054" class="photo-card">
          <img src="/images/home/flujostato.jpg" alt="Flujostato de priorización ON/OFF Bitron" loading="lazy" />
          <span class="photo-card__label">Flujostato Bitron ON/OFF</span>
        </a>
        <a href="/repuestos/ventilador-peisa-47w-90000090" class="photo-card">
          <img src="/images/home/ventilador.jpg" alt="Ventilador forzador 47W para caldera Peisa" loading="lazy" />
          <span class="photo-card__label">Ventilador forzador 47W</span>
        </a>
        <a href="/repuestos/kit-valvula-detentor-escuadra-media" class="photo-card">
          <img src="/images/home/kit-valvula.jpg" alt="Kit válvula y detentor escuadra ½ pulgada" loading="lazy" />
          <span class="photo-card__label">Kit válvula + detentor ½"</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Premium showcase -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <div class="section-header">
        <p class="section-header__label">Criterio Térmico</p>
        <h2>Más que un repuesto</h2>
        <p class="section-header__desc">
          Asesoramiento técnico incluido en cada pieza que vendemos.
        </p>
      </div>

      <div class="premium-showcase">
        <div class="premium-row">
          <a href="/repuestos/termostato-ambiente-tactil-peisa" class="premium-row__media">
            <img src="/images/home/termostato-premium.jpg" alt="Termostato de ambiente táctil controlando la temperatura del hogar" loading="lazy" />
          </a>
          <div class="premium-row__text">
            <span class="premium-row__badge">Control de temperatura</span>
            <h3>Controlá el clima de tu hogar</h3>
            <p class="premium-row__desc">
              Un termostato táctil que responde bien es la diferencia entre pasar frío
              y tener la casa a la temperatura justa. En Criterio Térmico te asesoramos
              para elegir el que corresponde a tu caldera y te explicamos cómo instalarlo.
            </p>
            <a href="/repuestos/termostato-ambiente-tactil-peisa" class="btn btn--primary">Ver ficha técnica →</a>
          </div>
        </div>

        <div class="premium-row premium-row--reverse">
          <a href="/repuestos/kit-valvula-detentor-escuadra-media" class="premium-row__media">
            <img src="/images/home/valvulas-detentores-premium.jpg" alt="Válvulas y detentores para radiadores en un ambiente hogareño" loading="lazy" />
          </a>
          <div class="premium-row__text">
            <span class="premium-row__badge">Regulación por ambiente</span>
            <h3>Válvulas y detentores para tus radiadores</h3>
            <p class="premium-row__desc">
              Regulá o cortá el flujo de cada radiador de forma individual. Con la
              pieza original y el asesoramiento de 20 años de experiencia de Criterio
              Térmico, cada ambiente queda a la temperatura que necesitás.
            </p>
            <a href="/repuestos/kit-valvula-detentor-escuadra-media" class="btn btn--primary">Ver ficha técnica →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Repuestos disponibles -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-header__label">Repuestos disponibles</p>
        <h2>Lo que tenemos en stock</h2>
        <p class="section-header__desc">
          Repuestos originales Peisa listos para retiro en Villa Urquiza, CABA.
        </p>
      </div>

      <div class="product-grid">
        {repuestosDestacados.map((item) => {
          const r = item.data;
          return (
            <a href={`/repuestos/${r.slug}`} class="card" style="text-decoration: none;">
              <img
                src={r.imagen}
                alt={r.nombre}
                class="card__image"
                loading="lazy"
                width="600"
                height="600"
              />
              <div class="card__body">
                {r.codigo && <span class="card__code">Cód. {r.codigo}</span>}
                <h3 class="card__title">{r.nombre}</h3>
                <p class="card__desc">{r.descripcion.substring(0, 100)}...</p>
                <div class="card__footer">
                  {r.precio_usd > 0 ? (
                    <span class="price-usd" style="font-size: var(--text-xl);">USD {r.precio_usd}</span>
                  ) : (
                    <span class="price-consult" style="font-size: var(--text-base);">Consultar precio</span>
                  )}
                  <span class={`badge ${r.disponible ? "badge--available" : "badge--unavailable"}`}>
                    {r.disponible ? "✓ Disponible" : "Sin stock"}
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <div style="text-align: center; margin-top: var(--space-8);">
        <a href="/repuestos" class="btn btn--secondary btn--lg">Ver todos los repuestos →</a>
      </div>
    </div>
  </section>

  <!-- Diagnostic CTA -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container" style="text-align: center;">
      <div class="section-header">
        <p class="section-header__label">¿Preferís hablar directo?</p>
        <h2>Escribinos por WhatsApp</h2>
        <p class="section-header__desc">
          Contanos qué le pasa a tu caldera y te decimos si es un repuesto,
          una instalación, o algo que podés resolver vos mismo.
        </p>
      </div>
      <WhatsAppButton mensaje={siteConfig.whatsappMensajeGenerico} />
    </div>
  </section>
</BaseLayout>
