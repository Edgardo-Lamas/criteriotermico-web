---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  hideChrome?: boolean;
}

const { title, description, ogImage = "/images/og-default.png", canonicalUrl, hideChrome = false } = Astro.props;
const currentPath = Astro.url.pathname;
// Única fuente de verdad: `site` en astro.config.mjs. Cuando esto era una constante
// hardcodeada acá, el dominio quedó duplicado en seis archivos y al cambiarlo se
// actualizaba solo uno — el canonical y la og:image seguían apuntando a un dominio
// muerto. Al comprar el dominio propio alcanza con tocar astro.config.mjs.
const siteUrl = Astro.site!.origin;
const fullCanonical = canonicalUrl || `${siteUrl}${currentPath}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Criterio Térmico" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Runs before first paint so [data-reveal] only hides content when JS
         can actually reveal it again (see .js-reveal rules in global.css) -->
    <script is:inline>
      document.documentElement.classList.add("js-reveal");
    </script>
  </head>
  <body>
    {!hideChrome && <Header currentPath={currentPath} />}

    <main>
      <slot />
    </main>

    {!hideChrome && <Footer />}
    {!hideChrome && <WhatsAppFloat />}

    <script>
      if (typeof IntersectionObserver !== "undefined") {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          // threshold 0 + margen inferior positivo: la sección arranca a
          // revelarse antes de entrar en pantalla, así llega ya legible.
          // Con threshold 0.1 las secciones más altas que el viewport
          // disparaban tarde y se leían a medio aparecer.
          { threshold: 0, rootMargin: "0px 0px 15% 0px" }
        );
        document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

        // Red de seguridad: un renderer que no scrollea (un crawler, un
        // servicio de preview) nunca dispara el observer y se llevaría la
        // página con las secciones invisibles. Pasado un margen, se muestran.
        setTimeout(() => {
          document.querySelectorAll("[data-reveal]").forEach((el) => el.classList.add("is-visible"));
        }, 2500);
      } else {
        document.querySelectorAll("[data-reveal]").forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
