---
/*
 * Íconos SVG del sitio. Reemplazan a los emojis del sistema, que se dibujan
 * distinto en cada plataforma y no heredan el color del texto.
 * Trazo, no relleno: acompañan al texto y toman su color vía currentColor.
 */
interface Props {
  name: "pin" | "clock";
  size?: number;
  class?: string;
}

const { name, size = 16, class: className } = Astro.props;

const paths: Record<Props["name"], string> = {
  pin: '<path d="M12 21s7-5.686 7-10.5A7 7 0 0 0 5 10.5C5 15.314 12 21 12 21Z"/><circle cx="12" cy="10.5" r="2.5"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5.2l3.2 1.9"/>',
};
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  set:html={paths[name]}
/>
