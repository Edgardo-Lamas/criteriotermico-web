---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SchemaMarkup from "../../components/SchemaMarkup.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const guias = await getCollection("instalacion");
  return guias.map((guia) => ({
    params: { slug: guia.id },
    props: { guia },
  }));
}

const { guia } = Astro.props;
const { Content } = await render(guia);
---

<BaseLayout
  title={`${guia.data.title} — Criterio Térmico`}
  description={guia.data.description}
>
  <SchemaMarkup type="article" data={guia.data} />
  <SchemaMarkup
    type="breadcrumb"
    data={{
      items: [
        { name: "Inicio", url: "https://criteriotermico.com.ar/" },
        { name: "Instalación", url: "https://criteriotermico.com.ar/instalacion" },
        { name: guia.data.title, url: `https://criteriotermico.com.ar/instalacion/${guia.id}` },
      ],
    }}
  />

  <section class="section">
    <div class="container">
      <Breadcrumbs
        items={[
          { label: "Instalación", href: "/instalacion" },
          { label: guia.data.title },
        ]}
      />

      <div class="article-content">
        <span class="article-card__tag" style="margin-bottom: var(--space-4); display: inline-block;">
          {guia.data.categoria}
        </span>
        <h1>{guia.data.title}</h1>
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>
